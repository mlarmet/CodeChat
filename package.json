{
	"name": "codechat",
	"displayName": "CodeChat",
	"description": "Local chat with another VSCode",
	"version": "0.0.1",
	"publisher": "mlarmet",
	"engines": {
		"vscode": "^1.110.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "CodeChat",
					"title": "CodeChat",
					"icon": "resources/icons/comment-discussion.svg"
				}
			]
		},
		"views": {
			"CodeChat": [
				{
					"id": "CodeChat.view",
					"name": "CodeChat",
					"icon": "resources/icons/comment-discussion.svg",
					"type": "webview",
					"when": "true"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "npm run check-types && npm run lint && node esbuild.mjs",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.mjs --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "npm run check-types && npm run lint && node esbuild.mjs --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/vscode": "^1.110.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.3",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^8.0.0"
	},
	"dependencies": {
		"date-fns": "^4.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"zustand": "^5.0.12"
	}
}
